            class="flex flex-col sm:flex-row justify-center gap-4 max-w-md mx-auto"
          >
            <CTAButton
              href={`tel:${siteConfig.phone.raw}`}
              variant="urgent"
              size="lg"
              fullWidth
            >
              <svg
                class="w-5 h-5 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
