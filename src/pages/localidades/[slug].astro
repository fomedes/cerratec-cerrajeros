              </svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-2">Conocemos la Zona</h3>
            <p class="text-sm text-slate-600">
              Cerrajeros locales que conocen {municipio.nombre}
            </p>
          </div>
        </div>
      </div>
    </SectionWrapper>

    <!-- Services Section -->
    <SectionWrapper bgClass="bg-slate-50">
      <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <div class="text-center mb-12">
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
            Servicios de Cerrajería en {municipio.nombre}
          </h2>
          <p class="text-slate-600 max-w-2xl mx-auto">
            Ofrecemos todos los servicios de cerrajería para hogares, negocios y
