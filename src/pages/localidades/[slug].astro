---
import CTAButton from "../../components/CTAButton.astro";
import FloatingWhatsApp from "../../components/FloatingWhatsApp.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import SectionWrapper from "../../components/SectionWrapper.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import { siteConfig } from "../../config/siteConfig";
import municipiosData from "../../data/municipios.json";
import serviciosData from "../../data/servicios.json";
import LocalidadLayout from "../../layouts/LocalidadLayout.astro";

// Generate static paths for all municipalities
export function getStaticPaths() {
  const paths: { params: { slug: string }; props: MunicipioProps }[] = [];

  municipiosData.grupos.forEach((grupo) => {
    grupo.municipios.forEach((municipio) => {
      paths.push({
        params: { slug: municipio.slug },
        props: {
          municipio,
          grupoNombre: grupo.nombre,
          municipiosCercanos: grupo.municipios
            .filter((m) => m.slug !== municipio.slug)
            .slice(0, 4),
        },
      });
    });
  });

  return paths;
}

interface Municipio {
  id: string;
  nombre: string;
  slug: string;
  provincia: string;
  descripcion: string;
  poblacion: string;
  codigoPostal: string;
  destacados: string[];
}

interface MunicipioProps {
  municipio: Municipio;
  grupoNombre: string;
  municipiosCercanos: Municipio[];
}

const { municipio, grupoNombre, municipiosCercanos } = Astro.props;
const servicios = serviciosData.servicios.slice(0, 6);
const marcas = serviciosData.marcas;
const whatsappUrl = `https://wa.me/${siteConfig.phone.whatsapp}?text=${encodeURIComponent(`Hola, necesito un cerrajero en ${municipio.nombre}`)}`;
---

<LocalidadLayout
  municipio={municipio.nombre}
  provincia={municipio.provincia}
  descripcion={municipio.descripcion}
>
