---
import CTAButton from "../components/CTAButton.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SectionWrapper from "../components/SectionWrapper.astro";
import { siteConfig } from "../config/siteConfig";
import BaseLayout from "../layouts/BaseLayout.astro";

const whatsappUrl = `https://wa.me/${siteConfig.phone.whatsapp}?text=${encodeURIComponent("Hola, necesito un cerrajero")}`;
---

<BaseLayout
  title="Contacto Cerrajero en Tarragona"
  description="Contacta con tu cerrajero de confianza en Tarragona. Disponibles 24/7 para urgencias. Llámanos o envíanos un WhatsApp para atención inmediata."
>
  <Header />

  <main class="pt-20">
    <!-- Hero Section -->
    <section
      class="relative bg-gradient-to-br from-blue-900 via-blue-800 to-slate-900 text-white py-16 sm:py-24 overflow-hidden"
    >
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"
      >
      </div>

      <div class="relative mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <div class="text-center">
          <div
            class="inline-flex items-center space-x-2 bg-amber-500/20 text-amber-300 px-4 py-2 rounded-full text-sm font-medium mb-6"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path
                d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
              ></path>
            </svg>
            <span>Disponibles 24/7</span>
          </div>

          <h1
            class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 leading-tight"
          >
            Contacto Cerrajero en Tarragona
          </h1>

          <p
            class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed"
          >
            Llámanos o escríbenos por WhatsApp para atención inmediata. Estamos
            aquí para ayudarte.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Methods -->
    <SectionWrapper bgClass="bg-white">
      <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
          <!-- Direct Contact -->
          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-6">
              Contacto directo
            </h2>
            <p class="text-slate-600 mb-8">
              Para urgencias, la forma más rápida es llamarnos directamente o
              enviarnos un WhatsApp. Te atendemos al momento.
            </p>

            <div class="space-y-4">
              <CTAButton
                href={`tel:${siteConfig.phone.raw}`}
                variant="urgent"
                size="lg"
                fullWidth
              >
                <svg
                  class="w-5 h-5 mr-2"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
                Llamar: {siteConfig.phone.formatted}
              </CTAButton>

              <CTAButton
                href={whatsappUrl}
                variant="secondary"
                size="lg"
                fullWidth
              >
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path>
                </svg>
                WhatsApp
              </CTAButton>
            </div>

            <!-- Info Cards -->
            <div class="mt-8 space-y-4">
              <div class="flex items-start space-x-4 p-4 bg-slate-50 rounded-lg">
                <div
                  class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0"
                >
                  <svg
                    class="w-5 h-5 text-blue-600"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900">Servicio 24 horas</h3>
                  <p class="text-sm text-slate-600">
                    Disponibles todos los días, festivos incluidos.
                  </p>
                </div>
              </div>

              <div class="flex items-start space-x-4 p-4 bg-slate-50 rounded-lg">
                <div
                  class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0"
                >
                  <svg
                    class="w-5 h-5 text-green-600"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900">
                    Interior de Tarragona
                  </h3>
                  <p class="text-sm text-slate-600">
                    Cubrimos todos los municipios de la zona interior.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-6">
              Envíanos un mensaje
            </h2>
            <p class="text-slate-600 mb-8">
              Si no es urgente, déjanos tus datos y te contactamos lo antes
              posible.
            </p>

            <form
              action="#"
              method="POST"
              class="space-y-5"
              name="contacto"
              data-netlify="true"
            >
              <input type="hidden" name="form-name" value="contacto" />

              <div>
                <label
                  for="nombre"
                  class="block text-sm font-medium text-slate-700 mb-1"
                >
                  Nombre
                </label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                  placeholder="Tu nombre"
                />
              </div>

              <div>
                <label
                  for="telefono"
                  class="block text-sm font-medium text-slate-700 mb-1"
                >
                  Teléfono
                </label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                  placeholder="Tu número de teléfono"
                />
              </div>

              <div>
                <label
                  for="mensaje"
                  class="block text-sm font-medium text-slate-700 mb-1"
                >
                  Mensaje
                </label>
                <textarea
                  id="mensaje"
                  name="mensaje"
                  rows="4"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition resize-none"
                  placeholder="¿En qué podemos ayudarte?"></textarea>
              </div>

              <button
                type="submit"
                class="w-full bg-blue-900 hover:bg-blue-950 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
              >
                Enviar mensaje
              </button>
            </form>
          </div>
        </div>
      </div>
    </SectionWrapper>
  </main>

  <Footer />
  <FloatingWhatsApp />
</BaseLayout>
