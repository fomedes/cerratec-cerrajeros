---
import CTAButton from "./CTAButton.astro";

interface Props {
  title: string;
  highlight?: string;
  subtitle?: string;
  badge?: string;
  trustLine?: string;
  showCallCTA?: boolean;
  showWhatsappCTA?: boolean;
  phone: string;
  whatsapp?: string;
  bgVariant?: "default" | "dark" | "light";
}

const {
  title,
  highlight,
  subtitle,
  badge = "Disponibles ahora",
  trustLine,
  showCallCTA = true,
  showWhatsappCTA = true,
  phone,
  whatsapp,
  bgVariant = "default",
} = Astro.props;

const backgroundStyles = {
  default: "from-blue-950 via-blue-900 to-slate-950",
  dark: "from-slate-950 via-slate-900 to-black",
  light: "from-blue-900 via-blue-800 to-slate-900",
};
---

<section
  class={`relative bg-gradient-to-br ${backgroundStyles[bgVariant]} text-white py-20 sm:py-28 overflow-hidden`}
>
  <div class="relative mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl text-center">
    {
      badge && (
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-medium mb-8">
          <span class="w-2 h-2 bg-emerald-400 rounded-full" />
          {badge}
        </div>
      )
    }

    <h1
      class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-tight mb-6"
    >
      {title}
      {
        highlight && (
          <>
            <br />
            <span class="text-amber-400">{highlight}</span>
          </>
        )
      }
    </h1>

    {
      subtitle && (
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto mb-6">
          {subtitle}
        </p>
      )
    }

    {
      trustLine && (
        <p class="text-base text-slate-400 max-w-xl mx-auto mb-10">
          {trustLine}
        </p>
      )
    }

    {
      (showCallCTA || showWhatsappCTA) && (
        <div class="flex flex-col sm:flex-row justify-center gap-4 max-w-lg mx-auto">
          {showCallCTA && (
            <CTAButton
              href={`tel:${phone}`}
              variant="urgent"
              size="lg"
              fullWidth
            >
              📞 Llamar ahora
            </CTAButton>
          )}

          {showWhatsappCTA && whatsapp && (
            <CTAButton
              href={`https://wa.me/${whatsapp}`}
              variant="secondary"
              size="lg"
              fullWidth
              target="_blank"
              rel="noopener"
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp
            </CTAButton>
          )}
        </div>
      )
    }
  </div>
</section>
