---
import { siteConfig } from "../config/siteConfig";
import municipiosData from "../data/municipios.json";
import SocialLinks from "./SocialLinks.astro";

const grupos = municipiosData.grupos;
---

<header
  id="site-header"
  class="fixed top-0 z-50 w-full bg-white/95 backdrop-blur-md shadow-md transition-all duration-300"
>
  <div class="mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between py-4">
      <!-- Logo - Mobile Optimized -->
      <div class="flex items-center shrink-0">
        <a href="/" class="flex items-center space-x-1 sm:space-x-2">
          <div class="text-base sm:text-xl font-bold text-blue-900">
            CerraNova<span class="hidden sm:inline"> Cerrajeros 24h</span>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-6">
        <a
          href="/"
          class="text-slate-700 hover:text-amber-600 font-medium transition"
        >
          Inicio
        </a>
        <a
          href="/servicios"
          class="text-slate-700 hover:text-amber-600 font-medium transition"
        >
          Servicios
        </a>

        <!-- Poblaciones Dropdown -->
        <div class="relative group">
          <button
            class="flex items-center text-slate-700 hover:text-amber-600 font-medium transition"
          >
            Poblaciones
            <svg
              class="w-4 h-4 ml-1 transition-transform group-hover:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <!-- Dropdown Menu -->
          <div
            class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200"
          >
            <div
              class="bg-white rounded-xl shadow-2xl border border-slate-200 p-4 min-w-[500px]"
            >
              <div class="grid grid-cols-3 gap-4">
                {
                  grupos.map((grupo) => (
                    <div>
                      <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 px-2">
                        {grupo.nombre.replace(/Grupo \d+ - /, "")}
                      </h3>
                      <ul class="space-y-1">
                        {grupo.municipios.map((municipio) => (
                          <li>
                            <a
                              href={`/localidades/${municipio.slug}`}
                              class="flex items-center px-2 py-1.5 text-sm text-slate-700 hover:bg-amber-50 hover:text-amber-700 rounded-lg transition"
                            >
                              <img
                                src={`/images/crests/${municipio.slug}.webp`}
                                alt=""
                                class="w-5 h-5 mr-2 object-contain"
                              />
                              {municipio.nombre}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <a
          href="/sobre-nosotros"
          class="text-slate-700 hover:text-amber-600 font-medium transition"
        >
          Sobre Nosotros
        </a>
        <a
          href="/contacto"
          class="text-slate-700 hover:text-amber-600 font-medium transition"
        >
          Contacto
        </a>
      </div>

      <!-- Mobile-First CTAs -->
      <div class="flex items-center space-x-2 sm:space-x-3">
        <!-- Social Links - Desktop only -->
        <div class="hidden lg:flex items-center mr-2">
          <SocialLinks />
        </div>
        <!-- Call Button - Prominent on Mobile -->
        <a
          href={`tel:${siteConfig.phone.raw}`}
          class="flex items-center justify-center bg-blue-900/95 hover:bg-blue-800 text-white px-3 sm:px-5 py-2 sm:py-2.5 rounded-xl font-semibold transition-all duration-200 ease-out shadow-md hover:shadow-lg active:scale-[0.98]focus:outline-none focus:ring-2 focus:ring-blue-900 focus:ring-offset-2 touch-manipulation"
          aria-label="Llamar ahora"
        >
          <svg
            class="w-5 h-5 sm:w-6 sm:h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          <span class="ml-2 text-sm sm:text-base"
            >{siteConfig.phone.formatted}</span
          >
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="lg:hidden text-slate-700 hover:text-amber-600 focus:outline-none p-2 touch-manipulation"
          aria-label="Toggle menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              id="menu-icon"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
            <path
              id="close-icon"
              class="hidden"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Navigation - Full Width -->
    <div
      id="mobile-menu"
      class="hidden lg:hidden pb-4 border-t border-gray-200 mt-2"
    >
      <div class="flex flex-col space-y-1 pt-3">
        <a
          href="/"
          class="text-slate-700 hover:bg-amber-50 hover:text-amber-700 font-medium transition px-4 py-3 rounded-lg"
        >
          Inicio
        </a>
        <a
          href="/servicios"
          class="text-slate-700 hover:bg-amber-50 hover:text-amber-700 font-medium transition px-4 py-3 rounded-lg"
        >
          Servicios
        </a>

        <!-- Localidades Accordion -->
        <div class="localidades-accordion">
          <button
            id="localidades-toggle"
            class="flex items-center justify-between w-full text-slate-700 hover:bg-amber-50 hover:text-amber-700 font-medium transition px-4 py-3 rounded-lg"
          >
            <span>Localidades</span>
            <svg
              id="localidades-chevron"
              class="w-4 h-4 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <!-- Localidades List with max-height and scroll -->
          <div
            id="localidades-list"
            class="hidden mt-1 max-h-[60vh] overflow-y-auto"
          >
            {
              grupos.map((grupo, index) => (
                <div class="grupo-accordion border-l-2 border-slate-200 ml-4">
                  <button
                    class="grupo-toggle flex items-center justify-between w-full text-slate-600 hover:bg-amber-50 hover:text-amber-700 font-medium transition px-4 py-2 rounded-r-lg text-sm"
                    data-grupo={index}
                  >
                    <span>{grupo.nombre.replace(/Grupo \d+ - /, "")}</span>
                    <span class="flex items-center">
                      <span class="text-xs text-slate-400 mr-2">
                        {grupo.municipios.length}
                      </span>
                      <svg
                        class="grupo-chevron w-4 h-4 transition-transform"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 9l-7 7-7-7"
                        />
                      </svg>
                    </span>
                  </button>
                  <div class="grupo-list hidden pl-2" data-grupo-list={index}>
                    {grupo.municipios.map((municipio) => (
                      <a
                        href={`/localidades/${municipio.slug}`}
                        class="flex items-center text-slate-600 hover:bg-amber-50 hover:text-amber-700 transition px-4 py-2 rounded-lg text-sm"
                      >
                        <img
                          src={`/images/crests/${municipio.slug}.webp`}
                          alt=""
                          class="w-5 h-5 mr-2 object-contain"
                        />
                        {municipio.nombre}
                      </a>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <a
          href="/sobre-nosotros"
          class="text-slate-700 hover:bg-amber-50 hover:text-amber-700 font-medium transition px-4 py-3 rounded-lg"
        >
          Sobre Nosotros
        </a>
        <a
          href="/contacto"
          class="text-slate-700 hover:bg-amber-50 hover:text-amber-700 font-medium transition px-4 py-3 rounded-lg"
        >
          Contacto
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle with icon animation
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  mobileMenuButton?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });

  // Localidades accordion toggle
  const localidadesToggle = document.getElementById("localidades-toggle");
  const localidadesList = document.getElementById("localidades-list");
  const localidadesChevron = document.getElementById("localidades-chevron");

  localidadesToggle?.addEventListener("click", () => {
    localidadesList?.classList.toggle("hidden");
    localidadesChevron?.classList.toggle("rotate-180");
  });

  // Group accordions toggle
  const grupoToggles = document.querySelectorAll(".grupo-toggle");

  grupoToggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const grupoIndex = toggle.getAttribute("data-grupo");
      const grupoList = document.querySelector(
        `[data-grupo-list="${grupoIndex}"]`,
      );
      const chevron = toggle.querySelector(".grupo-chevron");

      // Close other groups (accordion behavior)
      grupoToggles.forEach((otherToggle) => {
        const otherIndex = otherToggle.getAttribute("data-grupo");
        if (otherIndex !== grupoIndex) {
          const otherList = document.querySelector(
            `[data-grupo-list="${otherIndex}"]`,
          );
          const otherChevron = otherToggle.querySelector(".grupo-chevron");
          otherList?.classList.add("hidden");
          otherChevron?.classList.remove("rotate-180");
        }
      });

      // Toggle current group
      grupoList?.classList.toggle("hidden");
      chevron?.classList.toggle("rotate-180");
    });
  });

  // Header scroll effect
  const header = document.getElementById("site-header")!;

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header.classList.add("rounded-xl", "shadow-lg");
      header.classList.add("scale-x-90");
      header.classList.add("mt-2");
    } else {
      header.classList.remove("rounded-xl", "shadow-lg");
      header.classList.remove("scale-x-90");
      header.classList.remove("mt-2");
    }
  });
</script>
