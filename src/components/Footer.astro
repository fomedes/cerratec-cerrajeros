---
import { siteConfig } from "../config/siteConfig";
import municipiosData from "../data/municipios.json";
import SocialLinks from "./SocialLinks.astro";

const currentYear = new Date().getFullYear();
const grupos = municipiosData.grupos;
---

<footer class="w-full bg-slate-900 text-slate-300 pt-12 pb-6">
  <div class="mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main Footer Content with margins -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      <!-- Company Info -->
      <div class="space-y-4">
        <h3 class="text-amber-400 text-lg font-bold mb-4">
          {siteConfig.name}
        </h3>
        <p class="text-sm leading-relaxed text-slate-400">
          Servicio profesional de cerrajería 24 horas en alrededores de
          Tarragona. Rápidos, confiables y siempre disponibles.
        </p>
        <SocialLinks />
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h3 class="text-white text-lg font-bold mb-4">Enlaces Rápidos</h3>
        <ul class="space-y-2 text-sm text-slate-400">
          <li>
            <a href="/" class="hover:text-amber-400 transition">Inicio</a>
          </li>
          <li>
            <a href="/servicios" class="hover:text-amber-400 transition"
              >Servicios</a
            >
          </li>
          <li>
            <a href="/localidades" class="hover:text-amber-400 transition"
              >Localidades</a
            >
          </li>
          <li>
            <a href="/sobre-nosotros" class="hover:text-amber-400 transition"
              >Sobre Nosotros</a
            >
          </li>
          <li>
            <a href="/contacto" class="hover:text-amber-400 transition"
              >Contacto</a
            >
          </li>
        </ul>
      </div>

      <!-- Service Areas - Mobile Friendly -->
      <div class="space-y-4">
        <h3 class="text-white text-lg font-bold mb-4">Zonas de Servicio</h3>
        <ul class="space-y-1 text-sm text-slate-400">
          {
            grupos.slice(0, 1).map((grupo) =>
              grupo.municipios.slice(0, 6).map((municipio) => (
                <li>
                  <a
                    href={`/localidades/${municipio.slug}`}
                    class="hover:text-amber-400 transition"
                  >
                    {municipio.nombre}
                  </a>
                </li>
              )),
            )
          }
          <li>
            <a
              href="/localidades"
              class="text-amber-400 hover:text-amber-300 transition font-medium"
              >Ver todas →</a
            >
          </li>
        </ul>
      </div>

      <!-- Contact Info - Mobile Optimized -->
      <div class="space-y-4">
        <h3 class="text-white text-lg font-bold mb-4">Contacto 24/7</h3>
        <div class="space-y-3 text-sm text-slate-400">
          <div class="flex items-start space-x-3">
            <svg
              class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <a
              href={`tel:${siteConfig.phone.raw}`}
              class="hover:text-amber-400 transition font-medium"
            >
              {siteConfig.phone.formatted}
            </a>
          </div>
          <div class="flex items-start space-x-3">
            <svg
              class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href={`mailto:${siteConfig.email}`}
              class="hover:text-amber-400 transition break-all"
            >
              {siteConfig.email}
            </a>
          </div>
          <div class="flex items-start space-x-3">
            <svg
              class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Disponible 24 horas<br />7 días a la semana</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div class="border-t border-slate-800 pt-6 mt-6">
      <div
        class="flex flex-col sm:flex-row justify-between items-center space-y-3 sm:space-y-0 text-sm text-slate-500"
      >
        <p>
          © {currentYear} - {siteConfig.name} 24h - Todos los derechos reservados.
        </p>
        <div class="flex space-x-4">
          <a href="/politica-privacidad" class="hover:text-amber-400 transition"
            >Privacidad</a
          >
          <a href="/aviso-legal" class="hover:text-amber-400 transition"
            >Aviso Legal</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
