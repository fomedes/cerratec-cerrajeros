---
import { siteConfig } from "../config/siteConfig";

const whatsappNumber = siteConfig.phone.whatsapp;
const defaultMessage = "¡Hola! Necesito un cerrajero urgente.";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(defaultMessage)}`;
---

<!-- Floating WhatsApp Button - Mobile Optimized -->
<div class="fixed bottom-6 right-4 sm:right-6 z-50 group">
  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 bg-green-500 hover:bg-green-600 text-white rounded-full shadow-2xl hover:shadow-3xl transition-all duration-300 hover:scale-110 active:scale-95 touch-manipulation"
    aria-label="Contactar por WhatsApp"
  >
    <!-- WhatsApp Icon -->
    <svg class="w-8 h-8 sm:w-9 sm:h-9" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
      ></path>
    </svg>

    <!-- Notification Pulse -->
    <span
      class="absolute top-0 right-0 block h-3 w-3 sm:h-4 sm:w-4 rounded-full bg-red-500 ring-2 ring-white animate-ping"
    ></span>
    <span
      class="absolute top-0 right-0 block h-3 w-3 sm:h-4 sm:w-4 rounded-full bg-red-500 ring-2 ring-white"
    ></span>
  </a>

  <!-- Tooltip - Hidden on very small screens -->
  <div
    class="hidden md:block absolute right-full mr-3 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap"
  >
    <div class="bg-gray-900 text-white text-sm px-4 py-2 rounded-lg shadow-xl">
      ¿Necesitas ayuda? ¡Escríbenos!
      <div
        class="absolute top-1/2 -translate-y-1/2 -right-1 w-2 h-2 bg-gray-900 rotate-45"
      >
      </div>
    </div>
  </div>
</div>

<!-- Mobile-specific call-to-action bar (only on very small screens when urgent) -->
<div
  class="fixed bottom-0 left-0 right-0 bg-green-500 text-white p-3 sm:hidden z-40 shadow-2xl transform translate-y-full transition-transform duration-300"
  id="mobile-whatsapp-bar"
>
  <div class="flex items-center justify-between max-w-md mx-auto">
    <div class="flex-1 mr-3">
      <p class="text-sm font-semibold">¿Emergencia?</p>
      <p class="text-xs opacity-90">Te respondemos al instante</p>
    </div>
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-white text-green-600 px-4 py-2 rounded-lg font-bold text-sm hover:bg-gray-100 active:bg-gray-200 transition touch-manipulation flex items-center space-x-2"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        ></path>
      </svg>
      <span>WhatsApp</span>
    </a>
  </div>
</div>

<script>
  // Show mobile WhatsApp bar after 5 seconds on mobile devices
  if (window.innerWidth < 640) {
    setTimeout(() => {
      const mobileBar = document.getElementById("mobile-whatsapp-bar");
      if (mobileBar) {
        mobileBar.style.transform = "translateY(0)";

        // Hide after 10 seconds
        setTimeout(() => {
          mobileBar.style.transform = "translateY(100%)";
        }, 10000);
      }
    }, 5000);
  }
</script>

<style>
  @keyframes ping {
    75%,
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  .animate-ping {
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
</style>
